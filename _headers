# Cloudflare Pages: games.imapp.shop
# imapp (https://imapp.shop) から iframe で埋め込まれるゲーム配信。

# ---------- burger (Burger Stack Rush / Phaser+Vite版) ----------
# imapp 配下からのみ iframe 許可。clickjacking 対策。
# 追加で許可したいプレビュー環境があればここに足す。
/burger/*
  Content-Security-Policy: frame-ancestors 'self' https://imapp.shop https://*.imapp.shop https://imapp.pages.dev https://*.imapp.pages.dev http://localhost:3000 http://127.0.0.1:3000

# Vite ビルド。差し替え事故防止を最優先し index.html と素材は常に再検証する。
# （JS は内容ハッシュ名なので本来長期キャッシュ可だが、確実な更新反映を優先）
/burger/index.html
  Cache-Control: no-cache, must-revalidate
/burger/assets/*
  Cache-Control: no-cache, must-revalidate

# ---------- packer-panic (ふんべつ！パッカーパニック) ----------
# 別開発の Web ゲーム (天使カーソル制) を iframe 埋め込み。
# 同じく imapp 配下からのみフレーム許可。
/packer-panic/*
  Content-Security-Policy: frame-ancestors 'self' https://imapp.shop https://*.imapp.shop https://imapp.pages.dev https://*.imapp.pages.dev http://localhost:3000 http://127.0.0.1:3000

# index.html は内容ハッシュなしで差し替わる → 常に最新化
/packer-panic/index.html
  Cache-Control: no-cache, must-revalidate
# 画像など同名で差し替わり得る素材があるため、確実な反映を優先して常に再検証。
# （JS は内容ハッシュ名なので 304 で済み、実害は小さい）
/packer-panic/assets/*
  Cache-Control: no-cache, must-revalidate
# Service Worker は古いものが残ると更新事故になるため必ず no-cache（他ゲームと統一）。
/packer-panic/sw.js
  Cache-Control: no-cache, must-revalidate
/packer-panic/manifest.webmanifest
  Cache-Control: no-cache, must-revalidate

# ---------- tsukurun (ツクルン / 家具組み立てタイムアタック) ----------
